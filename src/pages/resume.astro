---
import BaseLayout from "../layouts/BaseLayout.astro";
import Timeline from "../components/Timeline.astro";
import SkillTags from "../components/SkillTags.astro";
import resumeData from "../content/resume.json";

const { basics, experience, education } = resumeData;
---

<BaseLayout title="简历" description={basics.summary}>
  <div class="container resume-page">
    <div class="page-header">
      <h1>{basics.name}</h1>
      <p class="resume-title">{basics.title}</p>
      <p class="resume-meta">{basics.location} · {basics.email}</p>
      <p class="resume-summary">{basics.summary}</p>
    </div>
    <section class="resume-section">
      <h2>技能</h2>
      <SkillTags skills={basics.skills} />
    </section>
    <Timeline
      title="工作经历"
      items={experience.map((e) => ({ ...e }))}
    />
    <Timeline
      title="教育经历"
      items={education.map((e) => ({ ...e }))}
    />
  </div>
</BaseLayout>

<style>
  .resume-page {
    max-width: 800px;
    padding-top: calc(var(--header-height) + var(--space-3xl));
    padding-bottom: var(--space-3xl);
  }
  .page-header {
    margin-bottom: var(--space-2xl);
  }
  .page-header h1 {
    font-size: var(--text-4xl);
    font-weight: 800;
    margin-bottom: var(--space-xs);
  }
  .resume-title {
    font-size: var(--text-xl);
    color: var(--color-accent);
    margin-bottom: var(--space-xs);
  }
  .resume-meta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }
  .resume-summary {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--line-height-base);
  }
  .resume-section {
    margin-bottom: var(--space-2xl);
  }
  .resume-section h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-lg);
  }
</style>
