---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GiscusComments from "../../components/GiscusComments.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((p) => ({ params: { slug: p.id } }));
}

const { slug } = Astro.params;
const posts = await getCollection("posts");
const post = posts.find((p) => p.id === slug);
if (!post || post.data.draft) return Astro.redirect(`${base}404`);
const { data } = post;

const allPosts = (await getCollection("posts"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const idx = allPosts.findIndex((p) => p.id === slug);
const prev = idx > 0 ? allPosts[idx - 1] : null;
const next = idx < allPosts.length - 1 ? allPosts[idx + 1] : null;
---

<BaseLayout title={data.title} description={data.description} image={data.image}>
  <article class="container post-detail">
    <div class="page-header">
      <a href={`${base}posts`} class="back-link">← 返回文章列表</a>
      <h1>{data.title}</h1>
      <div class="meta">
        <time datetime={data.date.toISOString()}>
          {data.date.toLocaleDateString("zh-CN", { year: "numeric", month: "long", day: "numeric" })}
        </time>
        {data.updated && (
          <span>更新于 {data.updated.toLocaleDateString("zh-CN")}</span>
        )}
        {data.tags && data.tags.length > 0 && (
          <span class="tags">
            {data.tags.map((t: string) => <span class="tag">{t}</span>)}
          </span>
        )}
      </div>
    </div>
    {data.image && (
      <img src={data.image} alt={data.title} class="cover-image" />
    )}
    <div class="content">
      {post.rendered?.html && <Fragment set:html={post.rendered.html} />}
    </div>
    <nav class="post-nav" aria-label="文章导航">
      {prev && <a href={`/posts/${prev.id}`} class="nav-prev">← {prev.data.title}</a>}
      {next && <a href={`/posts/${next.id}`} class="nav-next">{next.data.title} →</a>}
    </nav>
    <GiscusComments category="Posts" />
  </article>
</BaseLayout>

<style>
  .post-detail {
    max-width: 800px;
    padding-top: calc(var(--header-height) + var(--space-2xl));
    padding-bottom: var(--space-3xl);
  }
  .page-header { margin-bottom: var(--space-xl); }
  .back-link {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    display: inline-block;
    margin-bottom: var(--space-md);
  }
  .back-link:hover { color: var(--color-accent); }
  .page-header h1 { font-size: var(--text-3xl); margin-bottom: var(--space-sm); }
  .meta {
    display: flex;
    gap: var(--space-md);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    flex-wrap: wrap;
    align-items: center;
  }
  .tags { display: flex; gap: var(--space-xs); flex-wrap: wrap; }
  .tag {
    font-size: var(--text-xs);
    padding: 2px 8px;
    background: var(--color-accent-muted);
    color: var(--color-accent);
    border-radius: var(--radius-full);
  }
  .cover-image {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-2xl);
  }
  .content {
    line-height: var(--line-height-base);
    color: var(--color-text-primary);
  }
  .content :global(h2) { margin-top: var(--space-2xl); margin-bottom: var(--space-md); font-size: var(--text-2xl); }
  .content :global(h3) { margin-top: var(--space-xl); margin-bottom: var(--space-sm); }
  .content :global(p) { margin-bottom: var(--space-md); }
  .content :global(ul), .content :global(ol) { list-style: disc; padding-left: var(--space-xl); margin-bottom: var(--space-md); }
  .content :global(li) { margin-bottom: var(--space-xs); }
  .content :global(code) {
    background: var(--color-bg-secondary);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    font-size: 0.9em;
  }
  .content :global(pre) {
    background: var(--color-bg-secondary);
    padding: var(--space-lg);
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin-bottom: var(--space-md);
  }
  .content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-md);
    margin: var(--space-md) 0;
    color: var(--color-text-secondary);
  }
  .content :global(img) {
    border-radius: var(--radius-md);
    margin: var(--space-md) auto;
  }
  .post-nav {
    display: flex;
    justify-content: space-between;
    margin-top: var(--space-3xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }
  .post-nav a {
    color: var(--color-accent);
    text-decoration: none;
    max-width: 45%;
    font-size: var(--text-sm);
  }
  .post-nav a:hover { text-decoration: underline; }
  .nav-next { text-align: right; margin-left: auto; }
</style>
