---
import type { ProjectFrontmatter } from "../types";
import { getImageMeta } from "../utils/image";

export interface Props {
  project: {
    data: ProjectFrontmatter;
    id: string;
  };
}

const { project } = Astro.props;
const { data, id } = project;

let orientation = "landscape";
let formatLabel = "";
if (data.image) {
  const imagePath = `public${data.image}`;
  const meta = await getImageMeta(imagePath);
  orientation = meta.orientation;
  formatLabel = meta.format.format;
}
---

<a href={`/projects/${id}`} class="project-card glass-card">
  {data.image && (
    <div class={`card-image orientation-${orientation}`}>
      <img src={data.image} alt={data.title} loading="lazy" />
      <span class="format-badge">{formatLabel}</span>
    </div>
  )}
  <div class="card-body">
    <h3 class="card-title">{data.title}</h3>
    {data.description && <p class="card-desc">{data.description}</p>}
    {data.tags && data.tags.length > 0 && (
      <div class="card-tags">
        {data.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    )}
  </div>
</a>

<style>
  .project-card {
    display: block;
    text-decoration: none;
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
    padding: 0;
  }
  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.15);
  }
  .card-image {
    background: var(--color-bg-secondary);
    position: relative;
    overflow: hidden;
  }
  .card-image img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    display: block;
  }
  .format-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    font-size: 10px;
    padding: 2px 6px;
    background: rgba(0,0,0,0.55);
    color: #fff;
    border-radius: 4px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .project-card:hover .format-badge {
    opacity: 1;
  }
  .card-body {
    padding: var(--space-lg);
  }
  .card-title {
    font-size: var(--text-lg);
    color: var(--color-text-primary);
    margin-bottom: var(--space-xs);
  }
  .card-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
    line-height: 1.5;
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }
  .tag {
    font-size: var(--text-xs);
    padding: 2px 8px;
    background: var(--color-accent-muted);
    color: var(--color-accent);
    border-radius: var(--radius-full);
  }
</style>
